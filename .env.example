# ═══════════════════════════════════════════════
#  MedAssist AI — Configuration
# ═══════════════════════════════════════════════

# LLM Provider: "ollama" (local) ou "openai"
LLM_PROVIDER=ollama

# Ollama (local — aucune donnée ne sort de votre machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI (optionnel — si LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Embeddings
EMBEDDING_MODEL=mistral          # mistral | openai

# Vector Store
FAISS_INDEX_PATH=./data/faiss_index

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS (frontend URL)
CORS_ORIGINS=http://localhost:3000
